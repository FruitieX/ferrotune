{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "enables permissions for mobile platforms",
  "windows": [
    "main"
  ],
  "platforms": [
    "android",
    "iOS"
  ],
  "permissions": [
    "core:default",
    "native-audio:allow-play",
    "native-audio:allow-pause",
    "native-audio:allow-stop",
    "native-audio:allow-seek",
    "native-audio:allow-get-state",
    "native-audio:allow-set-volume",
    "native-audio:allow-next-track",
    "native-audio:allow-play-at-index",
    "native-audio:allow-previous-track",
    "native-audio:allow-set-replay-gain",
    "native-audio:allow-set-repeat-mode",
    "native-audio:allow-update-starred-state",
    "native-audio:allow-get-safe-area-insets",
    "native-audio:allow-init-session",
    "native-audio:allow-update-settings",
    "native-audio:allow-start-playback",
    "native-audio:allow-start-offline-playback",
    "native-audio:allow-invalidate-queue",
    "native-audio:allow-soft-invalidate-queue",
    "native-audio:allow-toggle-shuffle",
    "native-audio:allow-debug-log",
    "native-audio:allow-get-cast-state",
    "native-audio:allow-request-cast-session",
    "native-audio:allow-stop-cast-session",
    "native-audio:allow-load-cast-media",
    "native-audio:allow-play-cast-media",
    "native-audio:allow-pause-cast-media",
    "native-audio:allow-stop-cast-media",
    "native-audio:allow-seek-cast-media",
    "native-audio:allow-set-cast-volume",
    "native-audio:allow-get-cast-media-status",
    "native-audio:allow-enqueue-download",
    "native-audio:allow-remove-download",
    "native-audio:allow-remove-all-downloads",
    "native-audio:allow-pause-downloads",
    "native-audio:allow-resume-downloads",
    "native-audio:allow-get-downloads",
    "native-audio:allow-set-download-wifi-only"
  ]
}
